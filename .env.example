SERVER_HOST=127.0.0.1
SERVER_PORT=8080

DB_URL=mysql+aiomysql://multimodalAgent:multimodalAgent@127.0.0.1:3306/multimodalAgent?charset=utf8mb4
REDIS_URL=redis://127.0.0.1:6379/0

AI_PROVIDER=ollama
AI_TEMPERATURE=0.35
AI_MAX_TOKENS=512
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=multimodalAgent-qwen2.5-7b-ft:latest
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

CHAT_HISTORY_LIMIT=10
CHAT_SHORT_MEMORY_TTL_HOURS=24

RAG_TOP_K=4
USE_CHROMA=true
CHROMA_BASE_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=multimodalAgent_knowledge
KNOWLEDGE_CHUNK_SIZE=512
KNOWLEDGE_CHUNK_OVERLAP=64

# Set WHISPER_MODE=openai and provide OPENAI_API_KEY or WHISPER_API_KEY for real transcription.
WHISPER_MODE=mock
WHISPER_BASE_URL=https://api.openai.com
WHISPER_API_KEY=
WHISPER_MODEL=whisper-1
MEDIAPIPE_MODE=local-rule
MEDIAPIPE_URL=http://127.0.0.1:8090/analyze
POSTER_PP_URL=http://127.0.0.1:8096
MULTIMODAL_TEXT_WEIGHT=0.1
MULTIMODAL_AUDIO_WEIGHT=0.4
MULTIMODAL_VISUAL_WEIGHT=0.5

MCP_EXCEL_MODE=mcp
MCP_EXCEL_URL=http://127.0.0.1:8080/mcp
MCP_EXCEL_LOCAL_PATH=./data/multimodalAgent-reports.xlsx
MCP_EMAIL_MODE=mcp
MCP_EMAIL_URL=http://127.0.0.1:8080/mcp
ALERT_MAIL_FROM=multimodalAgent-alerts@example.com
ALERT_MAIL_RECIPIENTS=counselor-alerts@example.com
ALERT_MAIL_MAX_RETRIES=2
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_SSL_ENABLE=false
